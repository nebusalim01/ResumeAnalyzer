@page "/upload"
@inject AuthService AuthService
@inject ResumeService ResumeService
@inject NavigationManager Navigation

@if (!AuthService.IsLoggedIn)
{
    Navigation.NavigateTo("/login");
    return;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">

            <!-- Page Title -->
            <div class="text-center mb-4 fade-in">
                <h2 style="font-weight:700;color:var(--dark)">
                    📄 Analyze Your Resume
                </h2>
                <p style="color:var(--gray)">
                    Upload your resume and get instant AI-powered feedback
                </p>
            </div>

            <div class="card fade-in">
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">
                            ⚠️ @errorMessage
                        </div>
                    }

                    <!-- File Upload -->
                    <div class="mb-4">
                        <label class="form-label">
                            Resume File
                            <span style="color:var(--gray);
                                font-weight:400">
                                (PDF or DOCX)
                            </span>
                        </label>
                        <div class="upload-zone">
                            <div style="font-size:2.5rem">📂</div>
                            <p style="color:var(--gray);margin:0.5rem 0">
                                Click to select your resume
                            </p>
                            <InputFile class="form-control mt-2"
                                       OnChange="HandleFileSelected"
                                       accept=".pdf,.docx" />
                        </div>
                        @if (selectedFile != null)
                        {
                            <div class="mt-2 p-2 rounded"
                                 style="background:#D1FAE5;
                                color:#065F46;
                                font-size:0.9rem">
                                ✅ @selectedFile.Name
                                (@((selectedFile.Size / 1024)) KB)
                            </div>
                        }
                    </div>

                    <!-- Job Description -->
                    <div class="mb-4">
                        <label class="form-label">
                            Job Description
                            <span class="badge ms-2"
                                  style="background:var(--light);
                                color:var(--gray)">
                                Optional
                            </span>
                        </label>
                        <textarea class="form-control"
                                  rows="5"
                                  placeholder="Paste the job description here to get a match score..."
                                      @bind="jobDescription">
                        </textarea>
                        </div>

                        <!-- Submit -->
                        <button class="btn btn-primary w-100 py-3"
                                style="font-size:1.05rem"
                                @onclick="HandleUpload"
                                disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border
                                    spinner-border-sm me-2">
                                </span>
                                <span>Analyzing your resume...</span>
                            }
                            else
                            {
                                <span>🚀 Upload & Analyze</span>
                            }
                        </button>

                    </div>
                </div>

                <!-- Tips Card -->
                <div class="card mt-3 fade-in"
                     style="background:linear-gradient(135deg,#EEF2FF,#E0E7FF)">
                    <div class="card-body py-3">
                        <p class="mb-1"
                               style="font-weight:600;color:var(--primary)">
                            💡 Tips for better results
                        </p>
                        <ul style="color:var(--gray);
                            font-size:0.9rem;
                            margin:0;
                            padding-left:1.2rem">
                            <li>Use PDF format for best parsing accuracy</li>
                            <li>Include the job description for match scoring</li>
                            <li>Make sure your resume is text-based, not scanned</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </div>

@code {
    private IBrowserFile? selectedFile;
    private string jobDescription = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        errorMessage = string.Empty;
    }

    private async Task HandleUpload()
    {
        errorMessage = string.Empty;

        if (selectedFile == null)
        {
            errorMessage = "Please select a file.";
            return;
        }

        // Validate file size (5MB max)
        if (selectedFile.Size > 5 * 1024 * 1024)
        {
            errorMessage = "File size must be less than 5MB.";
            return;
        }

        isLoading = true;

        try
        {
            using var stream = selectedFile.OpenReadStream(
                maxAllowedSize: 5 * 1024 * 1024);

            var result = await ResumeService.UploadResumeAsync(
                stream,
                selectedFile.Name,
                string.IsNullOrWhiteSpace(jobDescription)
                    ? null : jobDescription);

            if (result != null)
            {
                AppState.AnalysisResult = result;

                // Get latest resume ID
                var resumes = await ResumeService.GetMyResumesAsync();
                if (resumes.Any())
                {
                    AppState.CurrentResumeId = resumes
                        .OrderByDescending(r => r.UploadedAt)
                        .First().Id;

                    // Debug — check value
                    Console.WriteLine($"ResumeId saved: {AppState.CurrentResumeId}");
                }

                Navigation.NavigateTo("/result");
            }
            else
            {
                errorMessage = "Upload failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }

        isLoading = false;
    }
}